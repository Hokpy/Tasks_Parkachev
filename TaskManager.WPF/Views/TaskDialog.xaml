<Window x:Class="TaskManager.WPF.Views.TaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задача" Height="460" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Border Margin="20" Background="White" CornerRadius="10">
        <Border.Effect>
            <!-- Встроенная тень WPF — не требует сторонних библиотек -->
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Заголовок диалога -->
                <RowDefinition Height="*"/>     <!-- Форма -->
                <RowDefinition Height="Auto"/>  <!-- Кнопки -->
            </Grid.RowDefinitions>

            <!-- Заголовок диалога -->
            <TextBlock Grid.Row="0" x:Name="DialogTitle"
                       FontSize="17" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,16"/>

            <!-- Поля формы -->
            <StackPanel Grid.Row="1" Margin="0,0,0,16">

                <!-- Название -->
                <TextBlock Text="Название *" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleBox" FontSize="13" Padding="8,6"
                         BorderBrush="#BDC3C7" BorderThickness="1"
                         Margin="0,0,0,12"/>

                <!-- Описание -->
                <TextBlock Text="Описание" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <TextBox x:Name="DescriptionBox" FontSize="13" Padding="8,6"
                         BorderBrush="#BDC3C7" BorderThickness="1"
                         Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,12"/>

                <!-- Приоритет и Статус рядом -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Приоритет" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                        <ComboBox x:Name="PriorityBox" FontSize="13" Padding="6,5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Статус" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                        <ComboBox x:Name="StatusBox" FontSize="13" Padding="6,5"/>
                    </StackPanel>
                </Grid>

                <!-- Срок выполнения -->
                <TextBlock Text="Срок выполнения" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <DatePicker x:Name="DueDatePicker" FontSize="13"
                            SelectedDateFormat="Short" Margin="0,0,0,12"/>

                <!-- Важность -->
                <CheckBox x:Name="IsImportantBox" Content="⭐ Отметить как важную"
                          FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Кнопки диалога -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Отмена" Width="90" Height="35"
                        Background="#95A5A6" Foreground="White"
                        BorderThickness="0" FontSize="13"
                        Cursor="Hand" Margin="0,0,8,0"
                        Click="CancelButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5" Padding="10,5">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="✔ Сохранить" Width="110" Height="35"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand" Click="SaveButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5" Padding="10,5">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
